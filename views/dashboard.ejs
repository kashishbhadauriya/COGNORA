<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Cognora — Dashboard</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="/css/dashboard.css">
<style>
 
</style>
</head>
<body>

<!-- ═══ SIDEBAR ═══ -->
<aside class="sidebar">

  <div class="sidebar-brand">
    <div class="sidebar-logo">🧠</div>
    <div class="sidebar-name">Cog<span>nora</span></div>
  </div>

  <div class="nav-label">Main</div>
  <a href="/dashboard" class="nav-link active">
    <span class="nav-icon">⊞</span> Dashboard
  </a>

  <div class="nav-label">Tools</div>
  <a href="/summarize" class="nav-link">
    <span class="nav-icon">📄</span> PDF Summarizer
  </a>
  <a href="/quiz" class="nav-link">
    <span class="nav-icon">📋</span> Quiz Generator
  </a>
  <a href="/doubt" class="nav-link">
    <span class="nav-icon">💬</span> Doubt Solver
  </a>

  <div class="nav-label">Library</div>
  <a href="/notes" class="nav-link">
    <span class="nav-icon">🗂️</span> My Notes
  </a>

  <div class="sidebar-footer">
    <div class="user-row">
      <div class="avatar">👤</div>
      <div class="user-info">
        <div class="user-name">Student</div>
        <div class="user-role">Free Plan</div>
      </div>
    </div>
    <a href="/logout" class="logout-btn">
      <span>🚪</span> Log Out
    </a>
  </div>

</aside>

<!-- ═══ MAIN ═══ -->
<main class="main">

  <!-- Top bar -->
  <div class="topbar">
    <div class="topbar-left">
      <h1>Welcome back, <span>Student</span> 👋</h1>
      <p>Here's what's happening with your studies today.</p>
    </div>
    <div class="topbar-right">
      <div class="date-badge" id="dateBadge">—</div>
    </div>
  </div>

  <!-- Stats -->
  <div class="stats-row">
    <div class="stat-card" style="animation-delay:0s">
      <div class="stat-top">
        <div class="stat-icon lime">📄</div>
      </div>
      <div class="stat-label">PDFs Summarised</div>
    </div>
    <div class="stat-card" style="animation-delay:0.07s">
      <div class="stat-top">
        <div class="stat-icon teal">📋</div>
      </div>
      <div class="stat-label">Quizzes Generated</div>
    </div>
    <div class="stat-card" style="animation-delay:0.14s">
      <div class="stat-top">
        <div class="stat-icon pink">💬</div>
      </div>
      <div class="stat-label">Doubts Solved</div>
    </div>
    <div class="stat-card" style="animation-delay:0.21s">
      <div class="stat-top">
        <div class="stat-icon blue">🗂️</div>
      </div>
      <div class="stat-label">Notes Saved</div>
    </div>
  </div>

  <!-- Feature cards -->
  <div class="section-title">AI <span>Tools</span></div>
  <div class="features-grid">

    <a href="/summarize" class="feature-card lime" style="animation-delay:0.1s">
      <div class="feat-icon-wrap">📄</div>
      <div class="feat-content">
        <div class="feat-title">PDF Summarizer</div>
        <div class="feat-desc">Upload any PDF and instantly get a structured AI summary of key insights and concepts.</div>
      </div>
    </a>

    <a href="/quiz" class="feature-card teal" style="animation-delay:0.17s">
      <div class="feat-icon-wrap">📋</div>
      <div class="feat-content">
        <div class="feat-title">Quiz Generator</div>
        <div class="feat-desc">Turn your notes or PDFs into practice quiz questions with answers in seconds.</div>
      </div>
    </a>

    <a href="/doubt" class="feature-card pink" style="animation-delay:0.24s">
      <div class="feat-icon-wrap">💬</div>
      <div class="feat-content">
        <div class="feat-title">Doubt Solver</div>
        <div class="feat-desc">Ask any study question and get a clear, detailed explanation from AI instantly.</div>
      </div>
     
    </a>

  </div>

  <!-- Bottom row -->
  <div class="bottom-row">

  

    <!-- Study Tips -->
    <div class="panel-card">
      <div class="panel-card-head">
        <div class="panel-card-title">Study Tips</div>
        <span class="panel-card-link">From Cognora AI</span>
      </div>
      <div class="tips-list">
        <div class="tip-item">
          <div class="tip-num">1</div>
          <div class="tip-text">Summarise your PDFs before reading — get the big picture first, then dive deep.</div>
        </div>
        <div class="tip-item">
          <div class="tip-num">2</div>
          <div class="tip-text">Generate a quiz after each chapter to reinforce what you've learned.</div>
        </div>
        <div class="tip-item">
          <div class="tip-num">3</div>
          <div class="tip-text">Never leave a doubt unresolved — ask the AI and move forward with clarity.</div>
        </div>
      </div>
    </div>

  </div>

</main>

<script>
  // Live date
  const d = new Date();
  document.getElementById('dateBadge').textContent =
    d.toLocaleDateString('en-IN', { weekday:'short', day:'numeric', month:'short', year:'numeric' });

  // Animate stat cards on scroll / load
  const cards = document.querySelectorAll('.stat-card, .feature-card, .panel-card');
  const io = new IntersectionObserver(entries => {
    entries.forEach(e => { if(e.isIntersecting) e.target.style.opacity = '1'; });
  }, { threshold: 0.1 });
  cards.forEach(c => io.observe(c));
</script>
</body>
</html>