<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">

<title>Cognora — Dashboard</title>

<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">

<style>

:root{
--bg:#0b0c10;
--surface:#13151c;
--surface2:#1a1d27;
--border:rgba(255,255,255,0.08);
--accent:#c8f04c;
--accent2:#4cf0b8;
--accent3:#f04c8a;
--text:#e8eaf0;
--muted:#6b7080;
--radius:16px;
}

*{margin:0;padding:0;box-sizing:border-box;}

body{
font-family:'Outfit',sans-serif;
background:var(--bg);
color:var(--text);
display:flex;
min-height:100vh;
overflow-x:hidden;
}

/* SIDEBAR */

.sidebar{
width:260px;
background:var(--surface);
border-right:1px solid var(--border);
padding:30px 20px;
display:flex;
flex-direction:column;
gap:8px;
position:fixed;
height:100vh;
left:0;
top:0;
transition:0.3s;
z-index:1000;
}

.sidebar-brand{
display:flex;
align-items:center;
gap:10px;
margin-bottom:25px;
}

.sidebar-logo{
width:38px;
height:38px;
border-radius:10px;
background:linear-gradient(135deg,var(--accent),var(--accent2));
display:flex;
align-items:center;
justify-content:center;
font-size:18px;
}

.sidebar-name{
font-family:'Playfair Display',serif;
font-size:20px;
font-weight:900;
}

.sidebar-name span{
color:var(--accent);
}

.nav-label{
font-size:10px;
letter-spacing:1px;
color:var(--muted);
margin-top:15px;
}

.nav-link{
text-decoration:none;
color:var(--muted);
display:flex;
gap:10px;
align-items:center;
padding:10px 12px;
border-radius:8px;
font-size:14px;
transition:0.2s;
}

.nav-link:hover{
background:var(--surface2);
color:white;
}

.nav-link.active{
background:rgba(200,240,76,0.1);
color:var(--accent);
}

/* USER */

.sidebar-footer{
margin-top:auto;
border-top:1px solid var(--border);
padding-top:15px;
}

.user-row{
display:flex;
gap:10px;
align-items:center;
margin-bottom:10px;
}

.avatar{
width:34px;
height:34px;
background:#333;
border-radius:8px;
display:flex;
align-items:center;
justify-content:center;
}

.logout-btn{
display:block;
text-decoration:none;
color:var(--muted);
padding:8px;
border-radius:8px;
font-size:14px;
}

.logout-btn:hover{
background:rgba(240,76,138,0.1);
color:var(--accent3);
}

/* MAIN */

.main{
margin-left:260px;
padding:40px;
flex:1;
}

/* TOPBAR */

.topbar{
display:flex;
align-items:center;
justify-content:space-between;
margin-bottom:30px;
}

.menu-btn{
display:none;
font-size:22px;
background:none;
border:none;
color:white;
cursor:pointer;
}

.topbar h1{
font-family:'Playfair Display',serif;
font-size:28px;
}

.topbar span{
color:var(--accent);
}

/* STATS */

.stats-row{
display:grid;
grid-template-columns:repeat(4,1fr);
gap:18px;
margin-bottom:30px;
}

.stat-card{
background:var(--surface);
padding:20px;
border-radius:var(--radius);
border:1px solid var(--border);
}

.stat-icon{
font-size:20px;
margin-bottom:10px;
}

.stat-label{
color:var(--muted);
font-size:13px;
}

/* FEATURES */

.section-title{
font-family:'Playfair Display',serif;
font-size:20px;
margin-bottom:20px;
}

.section-title span{
color:var(--accent);
}

.features-grid{
display:grid;
grid-template-columns:repeat(3,1fr);
gap:20px;
margin-bottom:40px;
}

.feature-card{
background:var(--surface);
border:1px solid var(--border);
padding:25px;
border-radius:var(--radius);
text-decoration:none;
color:white;
transition:0.2s;
}

.feature-card:hover{
transform:translateY(-4px);
border-color:rgba(255,255,255,0.2);
}

.feat-icon{
font-size:24px;
margin-bottom:10px;
}

.feat-desc{
font-size:13px;
color:var(--muted);
margin-top:5px;
}

/* CHAT BUTTON */

#chatbot-btn{
position:fixed;
right:25px;
bottom:25px;
width:60px;
height:60px;
background:#7b5cff;
border-radius:50%;
display:flex;
align-items:center;
justify-content:center;
color:white;
font-size:26px;
text-decoration:none;
box-shadow:0 6px 20px rgba(0,0,0,0.4);
}

/* FOOTER */

.site-footer{
margin-top:50px;
text-align:center;
border-top:1px solid var(--border);
padding:20px;
}

.footer-icons a{
font-size:20px;
margin:0 10px;
color:#aaa;
}

.footer-icons a:hover{
color:#7b5cff;
}

.site-footer p{
font-size:13px;
color:#aaa;
margin-top:8px;
}

/* RESPONSIVE */

@media(max-width:1000px){

.stats-row{
grid-template-columns:repeat(2,1fr);
}

.features-grid{
grid-template-columns:repeat(2,1fr);
}

}

@media(max-width:768px){

.menu-btn{
display:block;
}

.sidebar{
transform:translateX(-100%);
}

.sidebar.active{
transform:translateX(0);
}

.main{
margin-left:0;
padding:20px;
}

.features-grid{
grid-template-columns:1fr;
}

.stats-row{
grid-template-columns:1fr 1fr;
}

}

</style>
</head>

<body>

<!-- SIDEBAR -->

<aside class="sidebar">

<div class="sidebar-brand">
<div class="sidebar-logo">🧠</div>
<div class="sidebar-name">Cog<span>nora</span></div>
</div>

<div class="nav-label">Main</div>

<a href="/dashboard" class="nav-link active">⊞ Dashboard</a>

<div class="nav-label">Tools</div>

<a href="/summarize" class="nav-link">📄 PDF Summarizer</a>
<a href="/quiz" class="nav-link">📋 Quiz Generator</a>
<a href="/doubt" class="nav-link">💬 Doubt Solver</a>
<a href="/flashcards" class="nav-link">🃏 Flashcards</a>

<div class="nav-label">Library</div>

<a href="/notes" class="nav-link">🗂 My Notes</a>

<div class="sidebar-footer">

<div class="user-row">
<div class="avatar">👤</div>
<div>
<div>Student</div>
<div style="font-size:11px;color:var(--muted)">Free Plan</div>
</div>
</div>

<a href="/logout" class="logout-btn">🚪 Logout</a>

</div>

</aside>

<!-- MAIN -->

<main class="main">

<div class="topbar">

<button class="menu-btn" onclick="toggleSidebar()">☰</button>

<div>
<h1>Welcome back, <span>Student</span> 👋</h1>
<p style="color:var(--muted);font-size:14px;">Your AI study dashboard</p>
</div>

<div id="dateBadge"></div>

</div>

<!-- STATS -->

<div class="stats-row">

<div class="stat-card">
<div class="stat-icon">📄</div>
<div class="stat-label">PDFs Summarised</div>
</div>

<div class="stat-card">
<div class="stat-icon">📋</div>
<div class="stat-label">Quizzes Generated</div>
</div>

<div class="stat-card">
<div class="stat-icon">💬</div>
<div class="stat-label">Doubts Solved</div>
</div>

<div class="stat-card">
<div class="stat-icon">🗂</div>
<div class="stat-label">Notes Saved</div>
</div>

</div>

<!-- FEATURES -->

<div class="section-title">AI <span>Tools</span></div>

<div class="features-grid">

<a href="/summarize" class="feature-card">
<div class="feat-icon">📄</div>
<div>PDF Summarizer</div>
<div class="feat-desc">Upload PDF and get instant AI summary.</div>
</a>

<a href="/quiz" class="feature-card">
<div class="feat-icon">📋</div>
<div>Quiz Generator</div>
<div class="feat-desc">Generate quizzes from notes or PDF.</div>
</a>

<a href="/doubt" class="feature-card">
<div class="feat-icon">💬</div>
<div>Doubt Solver</div>
<div class="feat-desc">Ask any study question instantly.</div>
</a>

<a href="/flashcards" class="feature-card">
<div class="feat-icon">🃏</div>
<div>Flashcards</div>
<div class="feat-desc">Create flashcards for fast revision.</div>
</a>

</div>

<!-- CHAT BUTTON -->

<a href="/chat" id="chatbot-btn">💬</a>

<!-- FOOTER -->

<footer class="site-footer">

<div class="footer-icons">

<a href="https://www.linkedin.com/in/kashish-bhadauriya-80781b316/" target="_blank">
<i class="fab fa-linkedin"></i>
</a>

</div>

<p>
© 2026 <strong>Cognora AI</strong>.  
Crafted with care for students everywhere 🎓
</p>

</footer>

</main>

<script>

function toggleSidebar(){
document.querySelector(".sidebar").classList.toggle("active");
}

const d=new Date();
document.getElementById("dateBadge").textContent=
d.toLocaleDateString("en-IN",{weekday:"short",day:"numeric",month:"short",year:"numeric"});

</script>

</body>
</html>