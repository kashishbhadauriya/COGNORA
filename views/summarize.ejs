<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>StudyMind AI — PDF Summarizer</title>
<link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700;900&family=Outfit:wght@300;400;500;600&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0b0c10;
    --surface: #13151c;
    --surface2: #1a1d27;
    --border: rgba(255,255,255,0.07);
    --accent: #c8f04c;
    --accent2: #4cf0b8;
    --text: #e8eaf0;
    --muted: #6b7080;
    --radius: 16px;
  }

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Outfit', sans-serif;
    min-height: 100vh;
    overflow-x: hidden;
  }

  body::before {
    content: '';
    position: fixed; inset: 0;
    background:
      radial-gradient(ellipse 60% 50% at 15% 20%, rgba(200,240,76,0.07) 0%, transparent 60%),
      radial-gradient(ellipse 50% 40% at 85% 75%, rgba(76,240,184,0.06) 0%, transparent 55%);
    pointer-events: none; z-index: 0;
  }

  .page {
    position: relative; z-index: 1;
    display: grid;
    grid-template-columns: 380px 1fr;
    min-height: 100vh;
  }

  /* ══ LEFT PANEL ══ */
  .panel-left {
    background: var(--surface);
    border-right: 1px solid var(--border);
    padding: 40px 32px;
    display: flex;
    flex-direction: column;
    gap: 28px;
    position: sticky;
    top: 0; height: 100vh;
    overflow-y: auto;
  }

  .brand { display: flex; align-items: center; gap: 12px; }
  .brand-icon {
    width: 40px; height: 40px;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 10px;
    display: grid; place-items: center;
    font-size: 20px;
  }
  .brand-name {
    font-family: 'Playfair Display', serif;
    font-size: 18px; font-weight: 700;
  }
  .brand-name span { color: var(--accent); }

  .panel-header h2 {
    font-family: 'Playfair Display', serif;
    font-size: 26px; font-weight: 900;
    margin-bottom: 8px; line-height: 1.2;
  }
  .panel-header p { color: var(--muted); font-size: 14px; line-height: 1.6; }

  .drop-zone {
    position: relative;
    border: 1.5px dashed rgba(200,240,76,0.25);
    border-radius: var(--radius);
    padding: 36px 20px;
    text-align: center; cursor: pointer;
    transition: all 0.25s ease;
    background: rgba(200,240,76,0.02);
  }
  .drop-zone:hover, .drop-zone.dragover {
    border-color: var(--accent);
    background: rgba(200,240,76,0.05);
  }
  .drop-zone.has-file {
    border-style: solid; border-color: var(--accent);
    background: rgba(200,240,76,0.06);
  }
  .drop-zone input[type="file"] {
    position: absolute; inset: 0; opacity: 0; cursor: pointer; width: 100%;
  }
  .drop-icon { font-size: 32px; display: block; margin-bottom: 12px; }
  .drop-title { font-size: 15px; font-weight: 600; margin-bottom: 4px; }
  .drop-sub { font-size: 13px; color: var(--muted); }

  .file-name {
    display: none; margin-top: 14px;
    background: rgba(200,240,76,0.1);
    border-radius: 8px; padding: 8px 14px;
    font-size: 13px; font-weight: 500;
    gap: 8px; align-items: center; color: var(--accent);
  }
  .file-name.show { display: flex; }

  .btn-submit {
    width: 100%; padding: 15px;
    background: var(--accent); color: #0b0c10;
    border: none; border-radius: var(--radius);
    font-family: 'Outfit', sans-serif;
    font-size: 15px; font-weight: 700;
    cursor: pointer; transition: all 0.2s ease;
    display: flex; align-items: center; justify-content: center; gap: 8px;
    letter-spacing: 0.3px;
  }
  .btn-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(200,240,76,0.25); }
  .btn-submit:active { transform: translateY(0); }
  .btn-submit.loading { opacity: 0.6; pointer-events: none; }

  .formats { display: flex; gap: 8px; flex-wrap: wrap; align-items: center; }
  .formats-label { font-size: 12px; color: var(--muted); }
  .format-tag {
    font-size: 11px; font-weight: 600;
    border: 1px solid var(--border);
    border-radius: 6px; padding: 3px 9px;
    color: var(--muted); letter-spacing: 0.5px; text-transform: uppercase;
  }

  .btn-secondary {
    width: 100%; padding: 13px;
    background: transparent; color: var(--text);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    font-family: 'Outfit', sans-serif;
    font-size: 14px; font-weight: 500;
    cursor: pointer; transition: all 0.2s ease;
    display: flex; align-items: center; justify-content: center; gap: 8px;
  }
  .btn-secondary:hover { border-color: var(--accent2); color: var(--accent2); }

  /* ══ RIGHT PANEL ══ */
  .panel-right {
    padding: 48px 56px;
    overflow-y: auto;
  }

  .summary-header {
    display: flex; align-items: flex-start;
    justify-content: space-between; gap: 20px;
    margin-bottom: 40px;
  }
  .summary-header h1 {
    font-family: 'Playfair Display', serif;
    font-size: 36px; font-weight: 900;
    line-height: 1.1; margin-bottom: 8px;
  }
  .summary-header h1 span { color: var(--accent); }
  .summary-header p { color: var(--muted); font-size: 15px; }

  .copy-btn {
    background: var(--surface2);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 8px 18px; border-radius: 8px;
    font-size: 13px; font-weight: 500;
    cursor: pointer; transition: all 0.2s;
    font-family: 'Outfit', sans-serif;
    white-space: nowrap; align-self: flex-start;
  }
  .copy-btn:hover { border-color: var(--accent2); color: var(--accent2); }

  /* Summary sections parsed from text */
  .summary-body {
    display: flex; flex-direction: column; gap: 16px;
  }

  .s-section {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    overflow: hidden;
    animation: fadeUp 0.4s ease both;
    transition: border-color 0.2s;
  }
  .s-section:hover { border-color: rgba(200,240,76,0.2); }

  @keyframes fadeUp {
    from { opacity: 0; transform: translateY(14px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  .s-section-head {
    display: flex; align-items: center; gap: 14px;
    padding: 20px 24px 16px;
    border-bottom: 1px solid var(--border);
  }
  .s-badge {
    width: 32px; height: 32px; flex-shrink: 0;
    background: linear-gradient(135deg, var(--accent), var(--accent2));
    border-radius: 8px;
    display: grid; place-items: center;
    font-size: 14px;
  }
  .s-section-title {
    font-size: 15px; font-weight: 600;
    letter-spacing: 0.2px;
  }

  .s-section-body {
    padding: 18px 24px;
    font-size: 14px; line-height: 1.8;
    color: rgba(232,234,240,0.85);
  }

  /* bullet points inside section */
  .s-section-body ul {
    padding-left: 18px;
    display: flex; flex-direction: column; gap: 6px;
  }
  .s-section-body li::marker { color: var(--accent); }

  /* Highlight card — first big takeaway */
  .s-highlight {
    background: linear-gradient(135deg, rgba(200,240,76,0.08), rgba(76,240,184,0.05));
    border: 1px solid rgba(200,240,76,0.18);
    border-radius: var(--radius);
    padding: 24px 28px;
    font-size: 16px; line-height: 1.75;
    font-weight: 400;
    color: var(--text);
    animation: fadeUp 0.35s ease both;
    position: relative;
  }
  .s-highlight::before {
    content: '✦';
    position: absolute; top: 20px; right: 22px;
    color: var(--accent); font-size: 18px; opacity: 0.4;
  }

  /* Raw fallback textarea */
  .raw-summary {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 28px;
    font-size: 14px; line-height: 1.9;
    color: var(--text);
    width: 100%; min-height: 360px;
    resize: vertical;
    font-family: 'Outfit', sans-serif;
  }

  /* Empty state */
  .empty-state {
    display: flex; flex-direction: column;
    align-items: center; justify-content: center;
    min-height: 60vh; gap: 16px; text-align: center;
  }
  .empty-icon {
    width: 72px; height: 72px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 20px;
    display: grid; place-items: center;
    font-size: 32px;
  }
  .empty-state h3 {
    font-family: 'Playfair Display', serif;
    font-size: 22px; font-weight: 700;
  }
  .empty-state p { color: var(--muted); font-size: 14px; max-width: 320px; line-height: 1.6; }

  #summaryText { display: none; }

  ::-webkit-scrollbar { width: 6px; }
  ::-webkit-scrollbar-track { background: transparent; }
  ::-webkit-scrollbar-thumb { background: rgba(255,255,255,0.08); border-radius: 4px; }

  @media (max-width: 900px) {
    .page { grid-template-columns: 1fr; }
    .panel-left { position: static; height: auto; }
    .panel-right { padding: 32px 20px; }
    .summary-header { flex-direction: column; }
  }
</style>
</head>
<body>

<div class="page">

  <!-- ═══ LEFT: Upload ═══ -->
  <aside class="panel-left">

    <div class="brand">
      <div class="brand-icon">🧠</div>
      <div class="brand-name">Study<span>Mind</span> AI</div>
    </div>

    <div class="panel-header">
      <h2>PDF Summarizer</h2>
      <p>Upload any PDF and let AI extract the key insights for you instantly.</p>
    </div>

    <form action="/summarize" method="POST" enctype="multipart/form-data" id="uploadForm">

      <div class="drop-zone" id="dropZone">
        <input type="file" name="file" accept="application/pdf,image/*" required id="fileInput">
        <span class="drop-icon">📄</span>
        <div class="drop-title">Drop your file here</div>
        <div class="drop-sub">or click to browse files</div>
        <div class="file-name" id="fileName">
          <span>✅</span>
          <span id="fileNameText"></span>
        </div>
      </div>

      <button type="submit" class="btn-submit" id="submitBtn" style="margin-top:16px;">
        ⚡ Generate Summary
      </button>

    </form>

    <div class="formats">
      <span class="formats-label">Supports</span>
      <span class="format-tag">PDF</span>
      <span class="format-tag">Images</span>
      <span class="format-tag">50MB max</span>
      <span class="format-tag">Any language</span>
    </div>

    <button class="btn-secondary" onclick="printSummary()">
      🖨️ Print Summary
    </button>

  </aside>

  <!-- ═══ RIGHT: Summary Output ═══ -->
  <main class="panel-right">

    <% if(summary){ %>

    <%
      /*
        Parse the summary into sections.
        Supports headings like:
          ## Overview
          **Key Points**
          1. Section Title
        Or falls back to splitting by double-newlines into paragraphs.
      */
      const raw = summary;
      const sectionIcons = ['📌','💡','📝','🔍','📊','🎯','⚡','🗂️','✅','🔑'];
      const headingReg = /^(?:#{1,3}\s+|\*{2}(.+?)\*{2}|(\d+)\.\s+)(.+)/;

      let sections = [];
      const lines = raw.split('\n');
      let cur = null;

      lines.forEach(line => {
        const l = line.trim();
        if(!l){ if(cur) { sections.push(cur); cur = null; } return; }

        // detect heading
        const hm = l.match(/^(#{1,3})\s+(.+)/) || l.match(/^\*\*(.+?)\*\*\s*$/) || l.match(/^(\d+)\.\s+([A-Z].{3,})/);
        if(hm){
          if(cur) sections.push(cur);
          const title = hm[2] || hm[1];
          cur = { title: title.replace(/\*\*/g,''), bullets: [] };
          return;
        }

        if(!cur) cur = { title: null, bullets: [] };

        // detect bullet
        const bm = l.match(/^[-•*]\s+(.+)/) || l.match(/^[A-Z0-9]\.\s+(.+)/);
        if(bm){ cur.bullets.push(bm[1]); return; }

        cur.bullets.push(l);
      });
      if(cur) sections.push(cur);
      sections = sections.filter(s => s.bullets.length > 0);
      const parsed = sections.length > 1;
    %>

    <!-- Header -->
    <div class="summary-header">
      <div>
        <h1>AI <span>Summary</span></h1>
        <p>Key insights extracted from your document.</p>
      </div>
      <button class="copy-btn" onclick="copySummary()">⎘ Copy All</button>
    </div>

    <% if(parsed){ %>

    <div class="summary-body">

      <% sections.forEach((sec, i) => { %>

        <% if(i === 0 && !sec.title && sec.bullets.length === 1){ %>
          <!-- First single-line paragraph → highlight card -->
          <div class="s-highlight" style="animation-delay:0s">
            <%= sec.bullets[0] %>
          </div>

        <% } else { %>
          <div class="s-section">
            <% if(sec.title){ %>
            <div class="s-section-head">
              <div class="s-badge"><%= sectionIcons[i % sectionIcons.length] %></div>
              <div class="s-section-title"><%= sec.title %></div>
            </div>
            <% } %>
            <div class="s-section-body">
              <% if(sec.bullets.length > 1){ %>
                <ul>
                  <% sec.bullets.forEach(b => { %><li><%= b %></li><% }); %>
                </ul>
              <% } else { %>
                <%= sec.bullets[0] %>
              <% } %>
            </div>
          </div>
        <% } %>

      <% }); %>
    </div>

    <% } else { %>
    <!-- Fallback raw -->
    <textarea class="raw-summary" readonly id="summaryTextVisible"><%= summary %></textarea>
    <% } %>

    <!-- hidden for copy/print -->
    <textarea id="summaryText" readonly><%= summary %></textarea>

    <% } else { %>

    <div class="empty-state">
      <div class="empty-icon">📄</div>
      <h3>No Summary Yet</h3>
      <p>Upload a PDF or image on the left and click Generate Summary — your insights will appear here.</p>
    </div>
    <textarea id="summaryText" readonly></textarea>

    <% } %>
  </main>

</div>

<script>
  const fileInput    = document.getElementById('fileInput');
  const dropZone     = document.getElementById('dropZone');
  const fileName     = document.getElementById('fileName');
  const fileNameText = document.getElementById('fileNameText');

  fileInput.addEventListener('change', () => {
    if(fileInput.files.length){
      fileNameText.textContent = fileInput.files[0].name;
      fileName.classList.add('show');
      dropZone.classList.add('has-file');
    }
  });

  dropZone.addEventListener('dragover',  e => { e.preventDefault(); dropZone.classList.add('dragover'); });
  dropZone.addEventListener('dragleave', ()  => dropZone.classList.remove('dragover'));
  dropZone.addEventListener('drop',      ()  => dropZone.classList.remove('dragover'));

  document.getElementById('uploadForm').addEventListener('submit', () => {
    document.getElementById('submitBtn').classList.add('loading');
  });

  function copySummary(){
    const t = document.getElementById('summaryText');
    navigator.clipboard.writeText(t.value);
    const btn = document.querySelector('.copy-btn');
    btn.textContent = '✓ Copied!';
    btn.style.color = '#4cf0b8';
    setTimeout(() => { btn.textContent = '⎘ Copy All'; btn.style.color = ''; }, 2000);
  }

  function printSummary(){
    const s = document.getElementById('summaryText').value;
    const w = window.open('', '', 'height=700,width=900');
    w.document.write(`<!DOCTYPE html><html><head><title>StudyMind AI Summary</title>
    <style>body{font-family:Georgia,serif;padding:48px;line-height:1.8;color:#111;max-width:720px;margin:auto}
    h2{font-size:28px;margin-bottom:24px;border-bottom:2px solid #000;padding-bottom:12px}
    p{white-space:pre-wrap;font-size:15px}</style></head>
    <body><h2>StudyMind AI — PDF Summary</h2><p>${s.replace(/</g,'&lt;')}</p></body></html>`);
    w.document.close(); w.print();
  }
</script>
</body>
</html>