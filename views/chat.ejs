<!DOCTYPE html>
<html>
<head>
<title>AI Chat</title>

<style>

body{
font-family: Arial;
background:#0f1020;
color:white;
display:flex;
flex-direction:column;
align-items:center;
}

#chatbox{
width:60%;
height:500px;
overflow-y:auto;
border:1px solid #444;
padding:20px;
margin-top:30px;
background:#1a1a35;
border-radius:10px;
}

.message{
margin:12px 0;
}

.user{
color:#7b9cff;
}

.ai{
color:#8affb1;
}

.input-area{
margin-top:20px;
display:flex;
gap:10px;
}

input{
width:400px;
padding:12px;
border-radius:8px;
border:none;
}

button{
padding:12px 20px;
border:none;
background:#7b5cff;
color:white;
border-radius:8px;
cursor:pointer;
}

button:hover{
background:#5e46d4;
}

</style>
</head>

<body>

<h1>🤖 AI Study Chat</h1>

<div id="chatbox"></div>

<div class="input-area">

<input id="message" placeholder="Ask anything...">

<button onclick="sendMessage()">Send</button>

</div>

<script>

async function sendMessage(){

const input = document.getElementById("message");
const msg = input.value.trim();

if(msg === "") return;

const chatbox = document.getElementById("chatbox");

// show user message
chatbox.innerHTML += `<div class="message user"><b>You:</b> ${msg}</div>`;

input.value="";

// send to backend
const res = await fetch("/chat",{
method:"POST",
headers:{
"Content-Type":"application/json"
},
body:JSON.stringify({message:msg})
});

const data = await res.json();

// show AI reply
chatbox.innerHTML += `<div class="message ai"><b>AI:</b> ${data.reply}</div>`;

// auto scroll
chatbox.scrollTop = chatbox.scrollHeight;

}

</script>

</body>
</html>